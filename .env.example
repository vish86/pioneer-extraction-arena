# Server-only — set in Vercel Project → Settings → Environment Variables
PIONEER_API_KEY=
PIONEER_BASE_URL=https://api.pioneer.ai

# Optional: if Pioneer expects a specific base model id for inference (default: base)
# PIONEER_BASE_MODEL_ID=base

# Hackathon (defaults match Dataset#0003 / Dataset#0004)
# PIONEER_TRAINING_DATASET=Dataset#0003
# PIONEER_EVAL_DATASET=Dataset#0004
# PIONEER_HACKATHON_TITLE=Hackathon
# Shown when GET /felix/deployments returns empty
# PIONEER_DEPLOYMENT_HINT=My team deployment
